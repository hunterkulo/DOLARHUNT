<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="stake">stake</variable>
    <variable id="last_digit">last_digit</variable>
  </variables>

  <block type="trade_definition" id="root" x="20" y="20">
    <statement name="INITIALIZATION">
      <block type="variables_set" id="set_init_stake">
        <field name="VAR" id="stake">stake</field>
        <value name="VALUE">
          <block type="math_number">
            <field name="NUM">0.35</field>
          </block>
        </value>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_market" id="market">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_10</field>
        <next>
          <block type="trade_definition_tradetype" id="display_logic">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="contract">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candle">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_tradeoptions" id="options">
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <block type="math_number">
            <field name="NUM">1</field>
          </block>
        </value>
        <value name="AMOUNT">
          <block type="variables_get">
            <field name="VAR" id="stake">stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <block type="math_number">
            <field name="NUM">3</field>
          </block>
        </value>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="before_logic" x="20" y="550">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="variables_set" id="get_digit">
        <field name="VAR" id="last_digit">last_digit</field>
        <value name="VALUE">
          <block type="last_digit"></block>
        </value>
        <next>
          <block type="controls_if" id="trend_check">
            <value name="IF0">
              <block type="logic_operation" id="logic_or_1">
                <field name="OP">OR</field>
                <value name="A">
                  <block type="logic_operation" id="logic_or_2">
                    <field name="OP">OR</field>
                    <value name="A">
                      <block type="logic_compare" id="comp_1">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get">
                            <field name="VAR" id="last_digit">last_digit</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number">
                            <field name="NUM">1</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <value name="B">
                      <block type="logic_compare" id="comp_2">
                        <field name="OP">EQ</field>
                        <value name="A">
                          <block type="variables_get">
                            <field name="VAR" id="last_digit">last_digit</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number">
                            <field name="NUM">2</field>
                          </block>
                        </value>
                      </block>
                    </value>
                  </block>
                </value>
                <value name="B">
                  <block type="logic_compare" id="comp_3">
                    <field name="OP">EQ</field>
                    <value name="A">
                      <block type="variables_get">
                        <field name="VAR" id="last_digit">last_digit</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number">
                        <field name="NUM">3</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="purchase" id="pur">
                <field name="PURCHASE_LIST">DIGITOVER</field>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="after_logic" x="20" y="850">
    <statement name="AFTERPURCHASE_STACK">
      <block type="stop" id="stop_bot"></block>
    </statement>
  </block>
</xml>